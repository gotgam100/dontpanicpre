rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 데이터: 본인만 읽기/쓰기
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 접속자 표시(Presence): 로그인한 사용자 누구나 읽기/쓰기
    match /presence/{docId} {
      allow read, write: if request.auth != null;
    }

    // 채팅: 로그인한 사용자 누구나 읽기/쓰기
    match /chats/{fileKey}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }

    // 1:1 DM: 대화 당사자(dmKey에 uid 포함)만 읽기/쓰기
    match /dms/{dmKey}/messages/{msgId} {
      allow read, write: if request.auth != null
        && dmKey.matches('.*' + request.auth.uid + '.*');
    }
  }
}
